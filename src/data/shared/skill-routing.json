{
  "version": "5.0",
  "updated": "2026-04-14T06:00:00Z",
  "framework_version": "6.0",
  "description": "Maps task types to primary and secondary skills. Used by PM workflow during parallel dispatch to auto-assign tasks, and separates local adapter directories from external connectors to reduce ecosystem drift. v3.0 adds on-demand skill loading (SoC item 1). v4.0 adds model tiering (item 5), batch dispatch (item 3), result forwarding (item 4), speculative preloading (item 6), and systolic chain protocol (item 7). v4.1 adds task complexity gate (item 8) \u2014 big.LITTLE hybrid dispatch.",
  "load_mode": "on_demand",
  "model_tiering": {
    "enabled": true,
    "version": "1.0",
    "description": "ANE mixed-precision analog: use sonnet for mechanical tasks, opus for judgment tasks. Mechanical tasks include file generation, token checks, template application, boilerplate. Judgment tasks include architecture decisions, review, research synthesis, UX heuristic evaluation.",
    "tiers": {
      "sonnet": {
        "description": "Fast, cost-efficient. For mechanical, deterministic, template-driven work.",
        "use_when": [
          "file_generation",
          "token_checks",
          "template_application",
          "boilerplate_code",
          "csv_sync",
          "label_updates"
        ]
      },
      "opus": {
        "description": "Deep reasoning. For judgment, synthesis, architecture, review.",
        "use_when": [
          "architecture_decisions",
          "code_review",
          "ux_heuristic_evaluation",
          "research_synthesis",
          "risk_assessment",
          "kill_criteria_evaluation"
        ]
      }
    },
    "fallback": "opus"
  },
  "phase_skills": {
    "_description": "Maps each lifecycle phase to the 1-2 skills whose SKILL.md should be loaded. Hub loads ONLY these files instead of all 11. Saves ~30K tokens/session. Inspired by Apple LoRA adapter hot-swap. v4.0 adds model_tier per phase (SoC item 5). If value is an array, treat as v5.0 format (no tier). If an object, read .skills for the skill list and .model_tier for the tier recommendation.",
    "research": {
      "skills": [
        "research",
        "cx"
      ],
      "model_tier": "opus"
    },
    "prd": {
      "skills": [
        "pm-workflow",
