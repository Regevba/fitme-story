# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sync script cache
.showcase-cache/
.sync-report.md

# unified-control-center sync artifacts (Pattern 4.b — Option A: committed snapshot)
# Vercel does not have FitTracker2 checked out, so the prebuild sync cannot
# run on the builder. Until we add Option B (FITTRACKER2_DEPLOY_TOKEN +
# vercel.json buildCommand) or Option C (graceful skip + committed fallback),
# these files are committed. Refresh locally with `npm run prebuild` and
# commit before each deploy.
# src/data/shared/
# src/data/features/
# src/data/freshness.json
